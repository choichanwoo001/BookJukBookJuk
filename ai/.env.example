OPENAI_API_KEY=your_openai_api_key_here
LIBRARY_API_KEY=your_library_api_key_here

# 알라딘 Open API TTB 키 (book_chat 기능에 필요)
# 발급: https://www.aladin.co.kr/ttb/wapi/wapiapply.aspx
ALADIN_API_KEY=your_aladin_ttb_key_here

# Wikipedia 요청이 403으로 막힐 때 설정하세요 (연락처 포함 권장)
# 예) BookChatBot/1.0 (mailto:me@example.com)
WIKI_USER_AGENT=BookChatBot/1.0 (mailto:your_email@example.com)

# 선택: 클러스터링 방식 (kmeans | dbscan). 없으면 kmeans
# CLUSTERING_METHOD=dbscan

# ── hybrid_recommender 선택적 설정 ─────────────────────────────────────────

# Neo4j KG 저장소 (미설정 시 NetworkX 인메모리로 자동 폴백)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=your_neo4j_password

# Pinecone 벡터 DB (미설정 시 numpy 인메모리로 자동 폴백)
# PINECONE_API_KEY=your_pinecone_api_key
# PINECONE_INDEX_NAME=bookjuk-books
